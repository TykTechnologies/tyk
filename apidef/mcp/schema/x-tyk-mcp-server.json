{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "primitives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "object",
            "properties": {
              "operationId": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "method": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]{1,128}$"
          },
          "description": {
            "type": "string"
          },
          "annotations": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "readOnlyHint": {
                "type": "boolean"
              },
              "destructiveHint": {
                "type": "boolean"
              },
              "idempotentHint": {
                "type": "boolean"
              },
              "openWorldHint": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "param": {
                  "type": "string"
                },
                "name": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9_.-]{1,128}$"
                },
                "description": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "allow": {
            "type": "boolean"
          },
          "inputSchema": {
            "type": "object",
            "additionalProperties": true
          },
          "outputSchema": {
            "type": "object",
            "additionalProperties": true
          },
          "parameterLocations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "parameterSourceNames": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "parameterSerializations": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "sourceName": {
                  "type": "string"
                },
                "location": {
                  "type": "string"
                },
                "style": {
                  "type": "string"
                },
                "explode": {
                  "type": "boolean"
                },
                "schemaType": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "parameterOrder": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requestBodyContentType": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
