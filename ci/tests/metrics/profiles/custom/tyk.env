TYK_LOGLEVEL=debug
TYK_GW_OPENTELEMETRY_METRICS_ENABLED=true
TYK_GW_OPENTELEMETRY_METRICS_EXPORTER=grpc
TYK_GW_OPENTELEMETRY_METRICS_ENDPOINT=otel-collector:4317
TYK_GW_OPENTELEMETRY_METRICS_EXPORTINTERVAL=5
TYK_GW_STORAGE_HOST=redis
TYK_GW_POLICIES_POLICYSOURCE=file
TYK_GW_DBAPPCONFOPTIONS_NODEISSEGMENTED=true
TYK_GW_DBAPPCONFOPTIONS_TAGS=production,edge,e2e-test
TYK_GW_OPENTELEMETRY_METRICS_APIMETRICS=[{"name":"custom.request.duration","type":"histogram","description":"Custom latency histogram with header dimension","histogram_source":"total","dimensions":[{"source":"metadata","key":"method","label":"http.request.method"},{"source":"metadata","key":"response_code","label":"http.response.status_code"},{"source":"metadata","key":"api_id","label":"tyk.api.id"},{"source":"header","key":"X-Tenant","label":"tenant","default":"unknown"}],"histogram_buckets":[0.005,0.01,0.05,0.1,0.5,1.0,5.0]},{"name":"custom.error.requests.total","type":"counter","description":"Error-only request counter","dimensions":[{"source":"metadata","key":"method","label":"http.request.method"},{"source":"metadata","key":"response_code","label":"http.response.status_code"},{"source":"metadata","key":"api_id","label":"tyk.api.id"}],"filters":{"status_codes":["4xx","5xx"]}},{"name":"custom.api.requests.total","type":"counter","description":"Custom counter with tenant dimension","dimensions":[{"source":"metadata","key":"method","label":"http.request.method"},{"source":"metadata","key":"api_id","label":"tyk.api.id"},{"source":"header","key":"X-Tenant","label":"tenant","default":"unknown"}]},{"name":"custom.tracked.requests.total","type":"counter","description":"Counter with listen_path and endpoint dimensions","dimensions":[{"source":"metadata","key":"method","label":"http.request.method"},{"source":"metadata","key":"api_id","label":"tyk.api.id"},{"source":"metadata","key":"listen_path","label":"tyk.listen_path"},{"source":"metadata","key":"endpoint","label":"tyk.endpoint","default":""}]},{"name":"custom.configdata.requests.total","type":"counter","description":"Counter with config_data dimensions","dimensions":[{"source":"metadata","key":"method","label":"http.request.method"},{"source":"metadata","key":"api_id","label":"tyk.api.id"},{"source":"config_data","key":"environment","label":"configdata.environment","default":""},{"source":"config_data","key":"team","label":"configdata.team","default":""}]}]
