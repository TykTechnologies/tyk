TYK_LOGLEVEL=debug
TYK_GW_OPENTELEMETRY_METRICS_ENABLED=true
TYK_GW_OPENTELEMETRY_METRICS_EXPORTER=grpc
TYK_GW_OPENTELEMETRY_METRICS_ENDPOINT=otel-collector:4317
TYK_GW_OPENTELEMETRY_METRICS_EXPORTINTERVAL=5
TYK_GW_OPENTELEMETRY_METRICS_CARDINALITYLIMIT=5
TYK_GW_STORAGE_HOST=redis
TYK_GW_POLICIES_POLICYSOURCE=file
TYK_GW_OPENTELEMETRY_METRICS_APIMETRICS=[{"name":"cardinality.test.requests.total","type":"counter","description":"Counter with high-cardinality header dimension for overflow testing","dimensions":[{"source":"header","key":"X-Request-ID","label":"request_id","default":"unknown"}]}]
