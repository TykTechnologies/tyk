TYK_LOGLEVEL=debug
TYK_GW_OPENTELEMETRY_ENABLED=true
TYK_GW_OPENTELEMETRY_EXPORTER=grpc
TYK_GW_OPENTELEMETRY_ENDPOINT=otel-collector:4317
TYK_GW_OPENTELEMETRY_METRICS_ENABLED=true
TYK_GW_OPENTELEMETRY_METRICS_EXPORTINTERVAL=5
TYK_GW_STORAGE_HOST=redis
TYK_GW_POLICIES_POLICYSOURCE=file
TYK_GW_DBAPPCONFOPTIONS_NODEISSEGMENTED=true
TYK_GW_DBAPPCONFOPTIONS_TAGS=production,edge,e2e-test
TYK_GW_OPENTELEMETRY_METRICS_APIMETRICS=[{"name":"tyk.mcp.requests.total","type":"counter","description":"MCP requests by method and primitive","dimensions":[{"source":"metadata","key":"mcp_method","label":"mcp.method.name"},{"source":"metadata","key":"mcp_primitive_type","label":"mcp.primitive.type"},{"source":"metadata","key":"mcp_primitive_name","label":"mcp.primitive.name"},{"source":"metadata","key":"mcp_error_code","label":"mcp.error.code"},{"source":"metadata","key":"response_code"},{"source":"metadata","key":"api_id"}]},{"name":"tyk.mcp.primitive.duration","type":"histogram","description":"MCP primitive execution duration","histogram_source":"upstream","dimensions":[{"source":"metadata","key":"mcp_primitive_type","label":"mcp.primitive.type"},{"source":"metadata","key":"mcp_primitive_name","label":"mcp.primitive.name"},{"source":"metadata","key":"api_id"}]},{"name":"http.server.request.duration","type":"histogram","histogram_source":"total","dimensions":[{"source":"metadata","key":"method"},{"source":"metadata","key":"response_code"},{"source":"metadata","key":"api_id"},{"source":"metadata","key":"mcp_method","label":"mcp.method.name"},{"source":"header","key":"Mcp-Session-Id","label":"mcp.session.id","default":""}]}]
